#!/usr/bin/env python3
"""Pully intricate-canary secret service.

Binds an HTTP/1.1 server to the Unix socket named by $SOCKET_PATH and answers
every request. It reads DRACON_SECRET from the environment (injected by systemd
via EnvironmentFile pointing at the warden-decrypted
/var/lib/pully-fleet/secrets/canary.env). The response status proves the
warden-encrypted secret was decrypted on the node and is available to the
running service at runtime: 200 when the secret is present, 500 when missing.

Layout mirrors the proven hello-world canary (socketserver.StreamRequestHandler
+ UnixStreamServer) so pully's socket health check passes reliably.
"""
import os
import socketserver

SOCKET_PATH = os.environ.get("SOCKET_PATH", "/run/pully-fleet/sockets/canary-secret.sock")
SECRET = os.environ.get("DRACON_SECRET")


def build_response():
    if SECRET:
        body = b"healthy: secret loaded"
        status_line = "HTTP/1.1 200 OK"
    else:
        body = b"unhealthy: DRACON_SECRET missing"
        status_line = "HTTP/1.1 500 Internal Server Error"
    return (
        f"{status_line}\r\n"
        "Content-Type: text/plain\r\n"
        f"Content-Length: {len(body)}\r\n"
        "Connection: close\r\n"
        "\r\n"
    ).encode("utf-8") + body


class Handler(socketserver.StreamRequestHandler):
    def handle(self):
        try:
            self.request.recv(4096)
        except OSError:
            pass
        try:
            self.wfile.write(build_response())
            self.wfile.flush()
        except OSError:
            pass


class UnixHTTPServer(socketserver.UnixStreamServer):
    allow_reuse_address = True


def main() -> None:
    sock_dir = os.path.dirname(SOCKET_PATH)
    os.makedirs(sock_dir, exist_ok=True)
    try:
        os.unlink(SOCKET_PATH)
    except FileNotFoundError:
        pass

    print(
        f"canary-secret listening on unix socket {SOCKET_PATH}; "
        f"DRACON_SECRET={'set' if SECRET else 'MISSING'}",
        flush=True,
    )
    httpd = UnixHTTPServer(SOCKET_PATH, Handler)
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        try:
            os.unlink(SOCKET_PATH)
        except OSError:
            pass


if __name__ == "__main__":
    main()
