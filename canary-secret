#!/usr/bin/env python3
"""Canary unix-socket HTTP service that consumes a warden-encrypted secret.

Reads DRACON_SECRET from the environment (injected by systemd EnvironmentFile
pointing at the warden-decrypted /var/lib/pully-fleet/secrets/canary.env).
Answers /health 200 only when the secret is present, proving consumption.
"""
import http.server
import socketserver
import os
import sys


class Handler(http.server.BaseHTTPRequestHandler):
    def _send(self, code, body: bytes):
        self.send_response(code)
        self.send_header("Content-Type", "text/plain")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        secret = os.environ.get("DRACON_SECRET")
        if self.path == "/health":
            if secret:
                self._send(200, b"healthy: secret loaded")
            else:
                self._send(500, b"unhealthy: DRACON_SECRET missing")
        elif self.path == "/secret-check":
            self._send(200 if secret else 500, b"present" if secret else b"absent")
        else:
            self._send(404, b"not found")

    def log_message(self, *args):
        pass


def main():
    sock = os.environ.get("SOCKET_PATH")
    if not sock:
        print("SOCKET_PATH not set", file=sys.stderr, flush=True)
        sys.exit(1)
    # Remove a stale socket from a previous run.
    try:
        os.unlink(sock)
    except FileNotFoundError:
        pass

    class UnixHTTPServer(socketserver.UnixStreamServer):
        def get_request(self):
            req, _ = super().get_request()
            return req, ("localhost", 0)

    secret = os.environ.get("DRACON_SECRET")
    print(
        f"canary-secret listening on unix {sock}; DRACON_SECRET={'set' if secret else 'MISSING'}",
        flush=True,
    )
    with UnixHTTPServer(sock, Handler) as srv:
        srv.serve_forever()


if __name__ == "__main__":
    main()
